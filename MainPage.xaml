<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="pitchr.MainPage"
             BackgroundColor="#0f0f0f">

    <Grid>
        <!--main grid-->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Simulated waveform using BoxView elements -->
        <Grid x:Name="WaveformGrid" Grid.Row="0" BackgroundColor="#000210">
            <BoxView Color="White" WidthRequest="5" HeightRequest="10" VerticalOptions="End" Margin="1,0,0,0"/>
            <BoxView Color="White" WidthRequest="5" HeightRequest="20" VerticalOptions="End" Margin="1,0,0,0"/>
            <BoxView Color="White" WidthRequest="5" HeightRequest="30" VerticalOptions="End" Margin="1,0,0,0"/>
            <BoxView Color="White" WidthRequest="5" HeightRequest="40" VerticalOptions="End" Margin="1,0,0,0"/>
            <BoxView Color="White" WidthRequest="5" HeightRequest="50" VerticalOptions="End" Margin="1,0,0,0"/>
            <BoxView Color="White" WidthRequest="5" HeightRequest="60" VerticalOptions="End" Margin="1,0,0,0"/>
            <BoxView Color="White" WidthRequest="5" HeightRequest="50" VerticalOptions="End" Margin="1,0,0,0"/>
            <BoxView Color="White" WidthRequest="5" HeightRequest="40" VerticalOptions="End" Margin="1,0,0,0"/>
            <BoxView Color="White" WidthRequest="5" HeightRequest="30" VerticalOptions="End" Margin="1,0,0,0"/>
            <BoxView Color="White" WidthRequest="5" HeightRequest="20" VerticalOptions="End" Margin="1,0,0,0"/>
            <BoxView Color="White" WidthRequest="5" HeightRequest="10" VerticalOptions="End" Margin="1,0,0,0"/>
        </Grid>

        <!--pitch bar / space to move on pitch change-->
        <Grid x:Name="PitchGrid" Grid.Row="0" BackgroundColor="#000210" Opacity="0.8">
            <BoxView x:Name="PitchBar"
                     Color="#ffffaa"
                     WidthRequest="200"
                     HeightRequest="7"
                     HorizontalOptions="Center"
                     VerticalOptions="Center"
                     Margin="0,20,0,0" />
        </Grid>

        <!-- note name -->
        <Label x:Name="noteName"
               Text="A"
               FontSize="48"
               FontAttributes="Bold"
               TextColor="#fffffb"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Grid.Row="1"
               Margin="0,20,0,0"/>

        <!-- Optional: Some additional info or controls -->
        <StackLayout Grid.Row="2"
                     Orientation="Horizontal"
                     HorizontalOptions="Center"
                     VerticalOptions="Center"
                     Margin="0,20,0,20">
            <Label x:Name="CurrentPitchLabel"
                   Text="440 Hz"
                   FontSize="18"
                   TextColor="#ffffbb"/>
        </StackLayout>
    </Grid>

</ContentPage>
